{
  "name": "tv-photo-slideshow",
  "version": "1.0.0",
  "description": "TV photo slideshow app with EXIF data display for LG webOS and Samsung Tizen",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext js,jsx",
    "deploy:aws": "cd aws-infrastructure && npm run deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/credential-providers": "^3.1003.0",
    "exifr": "^7.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "jsdom": "^28.1.0",
    "vite": "^5.4.2",
    "vitest": "^4.0.18"
  }
}
